DATABASE_URL=postgresql+asyncpg://stellalink:password@localhost:5432/stellalink
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-to-a-long-random-string-in-production
FRONTEND_BASE_URL=http://localhost:3000
ADMIN_EMAILS=admin@stellalink.app
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Auth email links and SMTP delivery.
# If SMTP_HOST is empty, emails are written to the backend log.
SMTP_ENABLED=true
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=15
SMTP_FROM=noreply@stellalink.app
SMTP_FROM_NAME=Stellalink
AUTH_DEBUG_TOKENS=false
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600
